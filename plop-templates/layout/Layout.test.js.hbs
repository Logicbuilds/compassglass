import React from 'react'
import { render } from '@testing-library/react'

import { {{ pascalCase name }} } from './{{ pascalCase name }}'

test('should render {{ pascalCase name }} without exploding', () => {
  const headMeta = {
    title: '{{ pascalCase name }}',
    meta: [
      {
        name: 'description',
        content: '{{ pascalCase name }} description',
      },
    ],
  };

  const { container } = render(<{{ pascalCase name }} headMeta={headMeta} />)
  expect(container).toBeInTheDocument()
})
