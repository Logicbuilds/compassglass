{
  "name": "compass-glass",
  "version": "2.0.0",
  "homepage": "https://compassglass.co.za",
  "private": true,
  "dependencies": {
    "@emailjs/browser": "^3.11.0",
    "@types/react-headroom": "^2.2.1",
    "@types/react-helmet": "^6.1.8",
    "change-case": "^4.1.1",
    "copy-dir": "^1.3.0",
    "dotenv": "^8.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-headroom": "^3.2.0",
    "react-helmet-async": "^1.3.0",
    "react-hook-form": "^7.48.0",
    "react-markdown": "^8.0.7",
    "react-router-dom": "^6.18.0",
    "react-scripts": "5.0.1",
    "react-switch": "^7.0.0",
    "recoil": "^0.7.7",
    "rgm": "^0.1.1",
    "sass": "^1.69.0",
    "uuid": "^9.0.1"
  },
  "scripts": {
    "prettier": "prettier --check --ignore-path=./.gitignore \"src/**/*.{js,jsx,ts,tsx,json,css,html,}\"",
    "prettier:fix": "prettier --write --ignore-path=./.gitignore \"src/**/*.{js,jsx,ts,tsx,json,css,html,}\"",
    "precommit": "pretty-quick --staged",
    "copy:content": "ts-node ./scripts/copy-content.ts",
    "wireup": "run-p -l wireup:*",
    "wireup:types": "ts-node ./scripts/global-types.ts",
    "wireup:sass": "ts-node ./scripts/sass-imports.ts",
    "wireup:routes": "ts-node ./scripts/global-routes.ts",
    "wireup:components": "ts-node ./scripts/component-exports.ts",
    "plop": "yarn plop:definitions && plop && yarn wireup",
    "plop:definitions": "ts-node ./scripts/plop-definitions.ts",
    "clean:definitions": "rimraf ./plop-templates/configs.generated.json",
    "start": "npm run wireup && react-scripts start",
    "build": "npm run wireup && react-scripts build",
    "test": "react-scripts test"
  },
  "eslintConfig": {
    "extends": "react-app"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^14.1.2",
    "@testing-library/user-event": "^14.5.1",
    "@types/jest": "^29.5.8",
    "@types/node": "^20.10.5",
    "@types/react": "^18.2.44",
    "@types/react-dom": "^18.2.17",
    "@types/react-helmet-async": "^1.0.3",
    "@types/react-router-dom": "^5.3.3",
    "@types/recoil": "^0.0.9",
    "husky": "^8.0.3",
    "minimatch": "^10.2.5",
    "npm-run-all": "^4.1.5",
    "plop": "^2.6.0",
    "prettier": "^3.1.0",
    "pretty-quick": "^3.1.3",
    "rimraf": "^5.0.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "wrangler": "^4.83.0"
  }
}
