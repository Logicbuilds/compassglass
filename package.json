{
  "name": "undefyned-starter",
  "version": "0.0.1",
  "private": true,
  "dependencies": {
    "@types/react-headroom": "^2.2.1",
    "change-case": "^4.1.1",
    "copy-dir": "^1.3.0",
    "dotenv": "^8.2.0",
    "emailjs-com": "^2.6.3",
    "react": "^16.13.1",
    "react-dom": "^16.13.1",
    "react-headroom": "^3.0.0",
    "react-helmet-async": "^1.0.6",
    "react-hook-form": "^6.1.0",
    "react-markdown": "^4.3.1",
    "react-router-dom": "^5.1.2",
    "react-scripts": "3.4.1",
    "react-toast-notifications": "^2.4.0",
    "recoil": "^0.0.7",
    "rgm": "^0.1.1",
    "sass": "^1.69.4",
    "uuidv4": "^6.0.8"
  },
  "scripts": {
    "prettier": "prettier --check --ignore-path=./.gitignore \"src/**/*.{js,jsx,ts,tsx,json,css,html,}\"",
    "prettier:fix": "prettier --write --ignore-path=./.gitignore \"src/**/*.{js,jsx,ts,tsx,json,css,html,}\"",
    "precommit": "pretty-quick --staged",
    "copy:content": "ts-node ./scripts/copy-content.ts",
    "wireup": "run-p -l 'wireup:**'",
    "wireup:types": "ts-node ./scripts/global-types.ts",
    "wireup:sass": "ts-node ./scripts/sass-imports.ts",
    "wireup:routes": "ts-node ./scripts/global-routes.ts",
    "wireup:components": "ts-node ./scripts/component-exports.ts",
    "plop": "yarn plop:definitions && plop && yarn wireup",
    "plop:definitions": "ts-node ./scripts/plop-definitions.ts",
    "clean:definitions": "rimraf ./plop-templates/configs.generated.json",
    "start": "yarn wireup && yarn copy:content && react-scripts start",
    "build": "yarn wireup && yarn copy:content && react-scripts build",
    "test": "react-scripts test"
  },
  "eslintConfig": {
    "extends": "react-app"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^4.2.4",
    "@testing-library/react": "^9.3.2",
    "@testing-library/user-event": "^7.1.2",
    "@types/jest": "^24.0.0",
    "@types/node": "^12.0.0",
    "@types/react": "^16.9.0",
    "@types/react-dom": "^16.9.0",
    "@types/react-helmet-async": "^1.0.3",
    "@types/react-router-dom": "^5.1.4",
    "@types/react-toast-notifications": "^2.4.0",
    "@types/recoil": "^0.0.0",
    "husky": "^4.2.5",
    "npm-run-all": "^4.1.5",
    "plop": "^2.6.0",
    "prettier": "2.0.5",
    "pretty-quick": "^2.0.1",
    "rimraf": "^3.0.2",
    "ts-node": "^8.10.1",
    "typescript": "~3.7.2"
  }
}